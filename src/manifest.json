{
    "manifest_version": 3,
    "name": "Cool Tab",
    "version": "1.17.8",
    "description": "Just a new tab for your browser, but cooler",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "host_permissions": [
        "https://query1.finance.yahoo.com/*",
        "https://query2.finance.yahoo.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icon16.png",
        "32": "icon32.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}
